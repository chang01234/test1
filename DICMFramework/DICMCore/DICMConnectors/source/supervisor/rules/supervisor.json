{
    "rules": [
        {
            "name": "Is sup0 available",
            "rule": "sup0avl=ddm(1): g_sup0avl=sup0avl"
        },
        {
            "name": "Is sup0 active",
            "rule": "sup0act=ddm(0): g_sup0act=sup0act,print(g_sup0act,g_sup0s1,g_sup0s2,g_s_state,g_l_state)"
        },
        {
            "name": "Set sup0type: Default state:door",
            "rule": "sup0type=ddm(1),g_sup0type=1 : if (g_sup0type!=sup0type,g_sup0type=sup0type),print(g_sup0type)"
        },
        {
            "comment": "Set state type S1",
            "name": "Set sup0state:  Default state type to S1=0",
            "rule": "sup0stype=ddm(0),g_sup0stype=0 : g_sup0stype=sup0stype,print(g_sup0stype)"
        },
        {
            "comment": "Set parameter, creates a reference parameter and links to variable",
            "name": "sup0param: ddmparam to listen and new value trigger generator",
            "rule": "sup0param=ddm,g_ref_sup0,mask=['or']: g_sup_value_trig=g_ref_sup0,if(g_sup0param != sup0param,g_sup_value_trig = g_ref_sup0, g_sup0param=sup0param,ref(g_ref_sup0, sup0param),print(g_ref_sup0,sup0param))"
        },
        {
            "name": "SUP0: ref param change-S1",
            "rule": "g_sup_value_trig,g_sup0act,g_sup0stype,mask=['or'] : if(g_sup0act && (g_sup0type==1) && (g_sup0stype!=1) && (g_sup_value_trig==g_sup0s1) && (g_s_state!=1),g_s_state=1,print(g_sup_value_trig,g_sup0s1,g_sup0stype,g_s_state))"
        },
        {
            "name": "SUP0: ref param change-S2",
            "rule": "g_sup_value_trig,g_sup0act,g_sup0stype,mask=['or'] : if(g_sup0act && (g_sup0type==1) && (g_sup0stype>=1) && (g_sup_value_trig==g_sup0s2) && (g_s_state!=2), g_s_state=2,print(g_sup_value_trig,g_sup0s2,g_sup0stype,g_s_state))"
        },
        {
            "comment": "Set state 1 value->S1",
            "name": "Set sup0s1: Set s1 value",
            "rule": "sup0s1=ddm(2000),g_sup0s1=2000 : g_sup0s1=sup0s1,print(sup0s1)"
        },
        {
            "comment": "Set state 2 value->S2",
            "name": "Set sup0s2: Set s2 value",
            "rule": "sup0s2=ddm(3000),g_sup0s2=3000 : g_sup0s2=sup0s2,print(sup0s2)"
        },
        {
            "comment": "Set state 1 timeout",
            "name": "Set sup0s1alt: s1 timeout (ms),Default to 5000",
            "rule": "sup0s1alt=ddm(5000),g_sup0s1alt=5000 : g_sup0s1alt=sup0s1alt,print(sup0s1alt)"
        },
        {
            "comment": "Set state 2 timeout",
            "name": "Set sup0s2alt: s2 timeout (ms),Default to 3000",
            "rule": "sup0s2alt=ddm(3000),g_sup0s2alt=3000 : g_sup0s2alt=sup0s2alt,print(sup0s2alt)"
        },
        {
            "comment": "State Alarm",
            "name": "sup0salarm: state alarm",
            "rule": "sup0salarm=ddm : g_sup0salarm=sup0salarm,print(sup0salarm)"
        },
        {
            "comment": "SUP0 state 1 timeout start, g_s_state is state variable 1 means S1, 2 = S2",
            "name": "S1_entry:Start state 1 timeout",
            "rule": "g_s_state,g_sup0act,mask=['or'] : if(g_sup0act && (g_sup0type==1) && (g_s_state==1) && (g_sup0s1alt>0),timer_off(g_s2timer_on),timer_on(g_s1timer_on, g_sup0s1alt),print(g_s_state, g_sup0s1alt))"
        },
        {
            "comment": "SUP0 state 1 timer == 0",
            "name": "S1_entry:Start state 1 timeout, no timeout",
            "rule": "g_s_state,g_sup0act,mask=['or'] : if(g_sup0act && (g_sup0type==1) && (g_s_state==1) && (g_sup0s1alt==0),timer_off(g_s2timer_on),pub(sup0salarm=1),print(g_s_state, g_sup0s1alt))"
        },
        {
            "comment": "SUP0 state 2 timeout start",
            "name": "S2_entry:Start state 2 timeout",
            "rule": "g_s_state,g_sup0act,mask=['or'] : if(g_sup0act && (g_sup0type==1) && (g_s_state==2) && (g_sup0s2alt>0),timer_off(g_s1timer_on),timer_on(g_s2timer_on, g_sup0s2alt),print(g_s_state, g_sup0s2alt))"
        },
        {
            "comment": "SUP0 state 2 timer == 0",
            "name": "S2_entry:Start state 2 timeout, no timeout",
            "rule": "g_s_state,g_sup0act,mask=['or'] : if(g_sup0act && (g_sup0type==1) && (g_s_state==2)&& (g_sup0s2alt==0),timer_off(g_s1timer_on),pub(sup0salarm=2),print(g_s_state, g_sup0s2alt))"
        },
        {
            "comment": "SUP0 s1 timer expiration",
            "name": "S1 timer expired-alarm",
            "rule": "g_s1timer_on : if(g_sup0act && (g_s_state==1),pub(sup0salarm=1),print(sup0salarm, g_s1timer_on))"
        },
        {
            "comment": "SUP0 s2 timer expiration",
            "name": "S2 timer expired-alarm",
            "rule": "g_s2timer_on : if(g_sup0act && (g_s_state==2),pub(sup0salarm=2),print(sup0salarm, g_s2timer_on))"
        },
        {
            "name": "Set level high upper limit",
            "rule": "sup0lhuplim=ddm(5000),g_sup0lhuplim=5000:g_sup0lhuplim=sup0lhuplim"
        },
        {
            "name": "Set level high lower limit",
            "rule": "sup0lhlolim=ddm(4000),g_sup0lhlolim=4000:g_sup0lhlolim=sup0lhlolim"
        },
        {
            "name": "Set level low upper limit",
            "rule": "sup0lluplim=ddm(3000),g_sup0lluplim=3000:g_sup0lluplim=sup0lluplim"
        },
        {
            "name": "Set level low lower limit",
            "rule": "sup0lllolim=ddm(2000),g_sup0lllolim=2000:g_sup0lllolim=sup0lllolim"
        },
        {
            "name": "Set level high timeout (ms)",
            "rule": "sup0lhalt=ddm(2000),g_sup0lhalt=2000:g_sup0lhalt=sup0lhalt"
        },
        {
            "name": "Set level low timeout (ms)",
            "rule": "sup0llalt=ddm(2000),g_sup0llalt=2000:g_sup0llalt=sup0llalt"
        },
        {
            "name": "Set level initial timeout (ms)",
            "rule": "sup0laltini=ddm(10000),g_sup0laltini=10000:g_sup0laltini=sup0laltini"
        },
        {
            "name": "Set level alarm",
            "rule": "sup0lalarm=ddm:g_sup0lalarm=sup0lalarm,print(g_sup0lalarm)"
        },
        {
            "name": "SUP0: ref param change-L:Init->Idle",
            "rule": "g_sup_value_trig,g_sup0act,g_sup0type,mask=['or'] : if(g_sup0act && (g_sup0type==0) && (g_sup_value_trig < g_sup0lhuplim) && (g_sup_value_trig > g_sup0lllolim) && (g_l_state==0),g_l_state=1,print(g_sup_value_trig,g_l_state))"
        },
        {
            "name": "SUP0: ref param change-L:Init->DebounceHigh",
            "rule": "g_sup_value_trig,g_sup0act,g_sup0type,mask=['or'] : if(g_sup0act && (g_sup0type==0) && (g_sup_value_trig > g_sup0lhuplim) && (g_l_state==0),g_l_state=2,timer_on(g_l1timer_on, g_sup0laltini),print(g_sup_value_trig,g_l_state))"
        },
        {
            "name": "SUP0: ref param change-L:Init->DebounceLow",
            "rule": "g_sup_value_trig,g_sup0act,g_sup0type,mask=['or'] : if(g_sup0act && (g_sup0type==0) && (g_sup_value_trig < g_sup0lllolim) && (g_l_state==0),g_l_state=3,timer_on(g_l1timer_on, g_sup0laltini),print(g_sup_value_trig,g_l_state))"
        },
        {
            "name": "SUP0: ref param change-L:Idle->DebounceHigh",
            "rule": "g_sup_value_trig,g_sup0act,g_sup0type,mask=['or'] : if(g_sup0act && (g_sup0type==0) && (g_sup_value_trig > g_sup0lhuplim) && (g_l_state==1),g_l_state=2,timer_on(g_l1timer_on, g_sup0lhalt),print(g_sup_value_trig,g_l_state))"
        },
        {
            "name": "SUP0: ref param change-L:Idle->DebounceLow",
            "rule": "g_sup_value_trig,g_sup0act,g_sup0type,mask=['or'] : if(g_sup0act && (g_sup0type==0) && (g_sup_value_trig < g_sup0lllolim) && (g_l_state==1),g_l_state=3,timer_on(g_l1timer_on, g_sup0llalt),print(g_sup_value_trig,g_l_state))"
        },
        {
            "name": "SUP0: ref param change-L:DebounceLow->Idle",
            "rule": "g_sup_value_trig,g_sup0act,g_sup0type,mask=['or'] : if(g_sup0act && (g_sup0type==0) && (g_sup_value_trig > g_sup0lluplim) && (g_l_state==3),g_l_state=1,pub(sup0lalarm=0),timer_off(g_l1timer_on),print(g_sup_value_trig,g_l_state))"
        },
        {
            "name": "SUP0: ref param change-L:DebounceHigh->Idle",
            "rule": "g_sup_value_trig,g_sup0act,g_sup0type,mask=['or'] : if(g_sup0act && (g_sup0type==0) && (g_sup_value_trig < g_sup0lhlolim) && (g_l_state==2),g_l_state=1,pub(sup0lalarm=0),timer_off(g_l1timer_on),print(g_sup_value_trig,g_l_state))"
        },
        {
            "comment": "SUP0 Level high debounce timer expiration",
            "name": "Level debounce high timer expired-alarm",
            "rule": "g_l1timer_on : if(g_sup0act && (g_l_state==2),pub(sup0lalarm=1),print(sup0lalarm, g_l1timer_on))"
        },
        {
            "comment": "SUP0 Level low debounce timer expiration",
            "name": "Level debounce high timer expired-alarm",
            "rule": "g_l1timer_on : if(g_sup0act && (g_l_state==3),pub(sup0lalarm=2),print(sup0lalarm, g_l1timer_on))"
        }
    ]
}