list(APPEND EXTRA_COMPILER_OPTIONS "")

# select same as IDF
if (${IDF_TARGET} STREQUAL "linux" AND BUILD_TESTING)
    # By pass CONFIG setting. No optimzation
    list(APPEND EXTRA_COMPILER_OPTIONS "-O0")
else()
if(CONFIG_COMPILER_OPTIMIZATION_SIZE)
    list(APPEND EXTRA_COMPILER_OPTIONS "-Os")
    if(CMAKE_C_COMPILER_ID MATCHES "GNU")
        list(APPEND EXTRA_COMPILER_OPTIONS "-freorder-blocks")
    endif()
elseif(CONFIG_COMPILER_OPTIMIZATION_DEFAULT)
    list(APPEND EXTRA_COMPILER_OPTIONS "-Og")
elseif(CONFIG_COMPILER_OPTIMIZATION_NONE)
    list(APPEND EXTRA_COMPILER_OPTIONS "-O0")
elseif(CONFIG_COMPILER_OPTIMIZATION_PERF)
    list(APPEND EXTRA_COMPILER_OPTIONS "-O2")
endif()
endif()

message(STATUS "Building using IDF VERSION: $ENV{IDF_VERSION}")
if ("$ENV{IDF_VERSION}" VERSION_GREATER_EQUAL "5.0.0")
    set (IDF_VER_5 TRUE)
else()
    set (IDF_VER_5 FALSE)
endif()
# Check IDF version.
if (IDF_VER_5)
    if (NOT "$ENV{IDF_VERSION}" VERSION_GREATER_EQUAL "5.3.2")
        message( FATAL_ERROR "${IDF_VER}: Not using required version when building (>= \"5.3.2\")")
    endif()
else()
    if (NOT "$ENV{IDF_VERSION}" VERSION_GREATER_EQUAL "4.4.6")
        message( FATAL_ERROR "${IDF_VER}: Not using required version when building (>= \"4.4.6\")")
    endif()
    if (NOT "$ENV{IDF_VERSION}" VERSION_GREATER_EQUAL "4.4.8")
        message( WARNING "${IDF_VER}: Not using preferred version when building (>= \"4.4.8\")")
    endif()
endif()

