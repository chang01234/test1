list (APPEND EXTRA_COMPILER_OPTIONS "-fstrict-volatile-bitfields" "-ffunction-sections" "-fdata-sections" "-std=gnu99" "-Wall" "-Wextra" "-Wno-unused-parameter" "-ggdb" )
list (APPEND EXTRA_COMPILER_OPTIONS "-fmacro-prefix-map=${CMAKE_SOURCE_DIR}=.")
else()
#IDF VER 5.3.2
list (APPEND EXTRA_COMPILER_OPTIONS "-ffunction-sections" "-fdata-sections" "-fstrict-volatile-bitfields" "-Wall" "-Wextra" "-Werror=all" "-Wno-unused-parameter" "-gdwarf-4" "-ggdb" "-fno-jump-tables" "-fno-tree-switch-conversion" "-std=gnu17" "-fstack-protector" "-Wno-old-style-declaration")
list (APPEND EXTRA_COMPILER_OPTIONS "-fmacro-prefix-map=${CMAKE_SOURCE_DIR}=.")
list (APPEND EXTRA_COMPILER_OPTIONS "-Wno-error=format" "-Wno-format" "-Wno-address-of-packed-member")
endif()
if (${IDF_TARGET} STREQUAL "linux")
